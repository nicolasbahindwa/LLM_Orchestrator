PYTHONDONTWRITEBYTECODE=1
# Copy to .env and fill provider secrets.

# Provider credentials and defaults used by orchestrator.yaml
ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_VERSION=2023-06-01
ANTHROPIC_TIMEOUT=60
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT=60
OPENAI_DEFAULT_MODEL=gpt-4o-mini

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120
OLLAMA_DEFAULT_MODEL=llama3.1:latest

# Routing
ORCHESTRATOR_ROUTING_STRATEGY=balanced
ORCHESTRATOR_FALLBACK_STRATEGY=same_provider_first
ORCHESTRATOR_MAX_FALLBACK_ATTEMPTS=3

# Cache
ORCHESTRATOR_CACHE_ENABLED=true
ORCHESTRATOR_CACHE_BACKEND=memory
ORCHESTRATOR_CACHE_TTL=3600
ORCHESTRATOR_CACHE_MAX_SIZE=1000
ORCHESTRATOR_REDIS_HOST=localhost
ORCHESTRATOR_REDIS_PORT=6379
ORCHESTRATOR_REDIS_DB=0
ORCHESTRATOR_REDIS_PASSWORD=
ORCHESTRATOR_REDIS_USERNAME=
ORCHESTRATOR_REDIS_PREFIX=llm_cache:
ORCHESTRATOR_REDIS_MAX_CONNECTIONS=50
ORCHESTRATOR_REDIS_SOCKET_TIMEOUT=5

# Resilience
ORCHESTRATOR_CB_ENABLED=true
ORCHESTRATOR_CB_FAILURE_THRESHOLD=5
ORCHESTRATOR_CB_RECOVERY_TIMEOUT=60
ORCHESTRATOR_RETRY_ENABLED=true
ORCHESTRATOR_RETRY_MAX_RETRIES=3
ORCHESTRATOR_RETRY_STRATEGY=exponential
ORCHESTRATOR_RETRY_BASE_DELAY=1.0
ORCHESTRATOR_RETRY_MAX_DELAY=60.0

# Monitoring
ORCHESTRATOR_LOGGING_ENABLED=true
ORCHESTRATOR_LOG_LEVEL=INFO
ORCHESTRATOR_LOG_FORMAT=json
ORCHESTRATOR_LOG_OUTPUT=stdout
ORCHESTRATOR_METRICS_ENABLED=true
ORCHESTRATOR_METRICS_TRACK_COSTS=true
ORCHESTRATOR_METRICS_TRACK_LATENCY_PERCENTILES=true
ORCHESTRATOR_PROMETHEUS_ENABLED=false
ORCHESTRATOR_PROMETHEUS_HOST=0.0.0.0
ORCHESTRATOR_PROMETHEUS_PORT=9464
ORCHESTRATOR_PROMETHEUS_START_HTTP_SERVER=true
ORCHESTRATOR_OTEL_ENABLED=false
ORCHESTRATOR_OTEL_SERVICE_NAME=llm-orchestrator
ORCHESTRATOR_OTEL_EXPORTER_ENDPOINT=
ORCHESTRATOR_OTEL_EXPORTER_INSECURE=true
ORCHESTRATOR_OBSERVABILITY_SINKS=

# Optional: used by create_orchestrator_from_env() loader path
LLM_ORCHESTRATOR_OPENAI_API_KEY=
LLM_ORCHESTRATOR_OPENAI_ENABLED=false
LLM_ORCHESTRATOR_OPENAI_DEFAULT_MODEL=gpt-4o-mini
LLM_ORCHESTRATOR_ANTHROPIC_API_KEY=
LLM_ORCHESTRATOR_ANTHROPIC_ENABLED=false
LLM_ORCHESTRATOR_ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
LLM_ORCHESTRATOR_OLLAMA_ENABLED=true
LLM_ORCHESTRATOR_OLLAMA_BASE_URL=http://localhost:11434
LLM_ORCHESTRATOR_OLLAMA_DEFAULT_MODEL=llama3.1:latest
LLM_ORCHESTRATOR_ROUTING_STRATEGY=balanced
LLM_ORCHESTRATOR_CACHE_ENABLED=true
LLM_ORCHESTRATOR_CACHE_TTL=3600
LLM_ORCHESTRATOR_MONITORING_METRICS_ENABLED=true
LLM_ORCHESTRATOR_MONITORING_METRICS_PROMETHEUS_ENABLED=false
LLM_ORCHESTRATOR_MONITORING_METRICS_PROMETHEUS_PORT=9464
LLM_ORCHESTRATOR_MONITORING_METRICS_OTEL_ENABLED=false
LLM_ORCHESTRATOR_MONITORING_METRICS_SINKS=
